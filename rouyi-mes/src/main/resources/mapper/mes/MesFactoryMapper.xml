<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mes.factory.mapper.MesFactoryMapper">

    <resultMap type="MesFactory" id="MesFactoryResult">
        <id     property="factoryId"    column="factory_id"    />
        <result property="factoryCode"  column="factory_code"  />
        <result property="factoryName"  column="factory_name"  />
        <result property="manager"      column="manager"       />
        <result property="status"       column="status"        />
        <result property="versionNo"    column="version_no"    />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
        <result property="revision"     column="revision"      />
        <result property="delFlag"      column="del_flag"      />
    </resultMap>

    <sql id="selectMesFactoryVo">
        select factory_id, factory_code, factory_name, manager, status, version_no,
               create_by, create_time, update_by, update_time, remark, revision, del_flag
        from mes_factory
    </sql>

    <select id="selectMesFactoryList" parameterType="MesFactory" resultMap="MesFactoryResult">
        <include refid="selectMesFactoryVo"/>
        <where>
            del_flag = '0'
            <if test="factoryCode != null and factoryCode != ''">
                and factory_code like concat('%', #{factoryCode}, '%')
            </if>
            <if test="factoryName != null and factoryName != ''">
                and factory_name like concat('%', #{factoryName}, '%')
            </if>
            <if test="manager != null and manager != ''">
                and manager like concat('%', #{manager}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
            <if test="createBy != null and createBy != ''">
                and create_by like concat('%', #{createBy}, '%')
            </if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != ''">
                and date_format(create_time, '%Y%m%d') &gt;= date_format(#{params.beginCreateTime}, '%Y%m%d')
            </if>
            <if test="params.endCreateTime != null and params.endCreateTime != ''">
                and date_format(create_time, '%Y%m%d') &lt;= date_format(#{params.endCreateTime}, '%Y%m%d')
            </if>
            <if test="updateBy != null and updateBy != ''">
                and update_by like concat('%', #{updateBy}, '%')
            </if>
            <if test="params.beginUpdateTime != null and params.beginUpdateTime != ''">
                and date_format(update_time, '%Y%m%d') &gt;= date_format(#{params.beginUpdateTime}, '%Y%m%d')
            </if>
            <if test="params.endUpdateTime != null and params.endUpdateTime != ''">
                and date_format(update_time, '%Y%m%d') &lt;= date_format(#{params.endUpdateTime}, '%Y%m%d')
            </if>
        </where>
        order by factory_id desc
    </select>

    <select id="selectMesFactoryByFactoryId" parameterType="Long" resultMap="MesFactoryResult">
        <include refid="selectMesFactoryVo"/>
        where factory_id = #{factoryId} and del_flag = '0'
    </select>

    <select id="checkFactoryCodeUnique" parameterType="String" resultMap="MesFactoryResult">
        <include refid="selectMesFactoryVo"/>
        where factory_code = #{factoryCode} and del_flag = '0' limit 1
    </select>

    <insert id="insertMesFactory" parameterType="MesFactory" useGeneratedKeys="true" keyProperty="factoryId">
        insert into mes_factory
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="factoryCode != null and factoryCode != ''">factory_code,</if>
            <if test="factoryName != null and factoryName != ''">factory_name,</if>
            <if test="manager != null">manager,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="versionNo != null">version_no,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="revision != null">revision,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="factoryCode != null and factoryCode != ''">#{factoryCode},</if>
            <if test="factoryName != null and factoryName != ''">#{factoryName},</if>
            <if test="manager != null">#{manager},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="versionNo != null">#{versionNo},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="revision != null">#{revision},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
        </trim>
    </insert>

    <update id="updateMesFactory" parameterType="MesFactory">
        update mes_factory
        <set>
            <if test="factoryCode != null and factoryCode != ''">factory_code = #{factoryCode},</if>
            <if test="factoryName != null and factoryName != ''">factory_name = #{factoryName},</if>
            <if test="manager != null">manager = #{manager},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="versionNo != null">version_no = #{versionNo},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="revision != null">revision = #{revision},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
        </set>
        where factory_id = #{factoryId}
    </update>

    <update id="deleteMesFactoryByFactoryId" parameterType="Long">
        update mes_factory set del_flag = '2' where factory_id = #{factoryId}
    </update>

    <update id="deleteMesFactoryByFactoryIds" parameterType="Long">
        update mes_factory set del_flag = '2' where factory_id in
        <foreach item="factoryId" collection="array" open="(" separator="," close=")">
            #{factoryId}
        </foreach>
    </update>
</mapper>
