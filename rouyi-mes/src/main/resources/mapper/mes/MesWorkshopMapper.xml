<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mes.workshop.mapper.MesWorkshopMapper">

    <resultMap type="MesWorkshop" id="MesWorkshopResult">
        <id     property="workshopId"    column="workshop_id"    />
        <result property="factoryId"     column="factory_id"     />
        <result property="factoryCode"   column="factory_code"   />
        <result property="factoryName"   column="factory_name"   />
        <result property="workshopCode"  column="workshop_code"  />
        <result property="workshopName"  column="workshop_name"  />
        <result property="status"        column="status"         />
        <result property="versionNo"     column="version_no"     />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"        column="remark"         />
        <result property="revision"      column="revision"       />
        <result property="delFlag"       column="del_flag"       />
    </resultMap>

    <resultMap type="MesFactoryOption" id="MesFactoryOptionResult">
        <id     property="factoryId"    column="factory_id"   />
        <result property="factoryCode"  column="factory_code" />
        <result property="factoryName"  column="factory_name" />
    </resultMap>

    <sql id="selectMesWorkshopVo">
        select w.workshop_id, w.factory_id, f.factory_code, f.factory_name,
               w.workshop_code, w.workshop_name, w.status, w.version_no,
               w.create_by, w.create_time, w.update_by, w.update_time,
               w.remark, w.revision, w.del_flag
        from mes_workshop w
        left join mes_factory f on f.factory_id = w.factory_id and f.del_flag = '0'
    </sql>

    <select id="selectMesWorkshopList" parameterType="MesWorkshop" resultMap="MesWorkshopResult">
        <include refid="selectMesWorkshopVo"/>
        <where>
            w.del_flag = '0'
            <if test="factoryCode != null and factoryCode != ''">
                and f.factory_code like concat('%', #{factoryCode}, '%')
            </if>
            <if test="factoryName != null and factoryName != ''">
                and f.factory_name like concat('%', #{factoryName}, '%')
            </if>
            <if test="workshopCode != null and workshopCode != ''">
                and w.workshop_code like concat('%', #{workshopCode}, '%')
            </if>
            <if test="workshopName != null and workshopName != ''">
                and w.workshop_name like concat('%', #{workshopName}, '%')
            </if>
            <if test="status != null and status != ''">
                and w.status = #{status}
            </if>
            <if test="createBy != null and createBy != ''">
                and w.create_by like concat('%', #{createBy}, '%')
            </if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != ''">
                and date_format(w.create_time, '%Y%m%d') &gt;= date_format(#{params.beginCreateTime}, '%Y%m%d')
            </if>
            <if test="params.endCreateTime != null and params.endCreateTime != ''">
                and date_format(w.create_time, '%Y%m%d') &lt;= date_format(#{params.endCreateTime}, '%Y%m%d')
            </if>
            <if test="updateBy != null and updateBy != ''">
                and w.update_by like concat('%', #{updateBy}, '%')
            </if>
            <if test="params.beginUpdateTime != null and params.beginUpdateTime != ''">
                and date_format(w.update_time, '%Y%m%d') &gt;= date_format(#{params.beginUpdateTime}, '%Y%m%d')
            </if>
            <if test="params.endUpdateTime != null and params.endUpdateTime != ''">
                and date_format(w.update_time, '%Y%m%d') &lt;= date_format(#{params.endUpdateTime}, '%Y%m%d')
            </if>
        </where>
        order by w.workshop_id desc
    </select>

    <select id="selectMesWorkshopByWorkshopId" parameterType="Long" resultMap="MesWorkshopResult">
        <include refid="selectMesWorkshopVo"/>
        where w.workshop_id = #{workshopId} and w.del_flag = '0'
    </select>

    <select id="checkWorkshopCodeUnique" parameterType="String" resultMap="MesWorkshopResult">
        <include refid="selectMesWorkshopVo"/>
        where w.workshop_code = #{workshopCode} and w.del_flag = '0' limit 1
    </select>

    <select id="selectFactoryByFactoryId" parameterType="Long" resultMap="MesFactoryOptionResult">
        select factory_id, factory_code, factory_name
        from mes_factory
        where factory_id = #{factoryId} and status = '0' and del_flag = '0'
    </select>

    <select id="selectFactoryByFactoryCode" parameterType="String" resultMap="MesFactoryOptionResult">
        select factory_id, factory_code, factory_name
        from mes_factory
        where factory_code = #{factoryCode} and status = '0' and del_flag = '0'
        limit 1
    </select>

    <select id="selectEnabledFactoryOptions" resultMap="MesFactoryOptionResult">
        select factory_id, factory_code, factory_name
        from mes_factory
        where status = '0' and del_flag = '0'
        order by factory_code
    </select>

    <insert id="insertMesWorkshop" parameterType="MesWorkshop" useGeneratedKeys="true" keyProperty="workshopId">
        insert into mes_workshop
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="factoryId != null">factory_id,</if>
            <if test="workshopCode != null and workshopCode != ''">workshop_code,</if>
            <if test="workshopName != null and workshopName != ''">workshop_name,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="versionNo != null">version_no,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="revision != null">revision,</if>
            <if test="delFlag != null and delFlag != ''">del_flag,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="factoryId != null">#{factoryId},</if>
            <if test="workshopCode != null and workshopCode != ''">#{workshopCode},</if>
            <if test="workshopName != null and workshopName != ''">#{workshopName},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="versionNo != null">#{versionNo},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="revision != null">#{revision},</if>
            <if test="delFlag != null and delFlag != ''">#{delFlag},</if>
        </trim>
    </insert>

    <update id="updateMesWorkshop" parameterType="MesWorkshop">
        update mes_workshop
        <set>
            <if test="factoryId != null">factory_id = #{factoryId},</if>
            <if test="workshopCode != null and workshopCode != ''">workshop_code = #{workshopCode},</if>
            <if test="workshopName != null and workshopName != ''">workshop_name = #{workshopName},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="versionNo != null">version_no = #{versionNo},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="revision != null">revision = #{revision},</if>
            <if test="delFlag != null and delFlag != ''">del_flag = #{delFlag},</if>
        </set>
        where workshop_id = #{workshopId}
    </update>

    <update id="deleteMesWorkshopByWorkshopId" parameterType="Long">
        update mes_workshop set del_flag = '2' where workshop_id = #{workshopId}
    </update>

    <update id="deleteMesWorkshopByWorkshopIds" parameterType="Long">
        update mes_workshop set del_flag = '2' where workshop_id in
        <foreach item="workshopId" collection="array" open="(" separator="," close=")">
            #{workshopId}
        </foreach>
    </update>
</mapper>
